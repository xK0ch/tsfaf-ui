# SPA-Rewrite ist nicht mehr noetig: app.config.ts nutzt Hash-Routing,
# also haben alle App-internen Pfade ein '#' und der Server sieht nur '/'.
# Falls der Hoster spaeter mod_rewrite einschaltet, kann hier ein klassischer
# Angular-SPA-Rewrite rein.

# Caching: hashed JS/CSS-Files lange cachen, index.html nie cachen.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|png|jpe?g|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Kompression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>
